# pnpm 엄격 모드에서 일부 도구가 peer 의존성을 호스팅된 node_modules에서 찾는
# 이슈 방지.
# - vitest: @testing-library/jest-dom이 require
# - testing-library: jsdom과의 상호작용
# - @eslint/eslintrc: next lint의 flat config 변환
public-hoist-pattern[]=*vitest*
public-hoist-pattern[]=*testing-library*
public-hoist-pattern[]=@eslint/eslintrc
public-hoist-pattern[]=eslint
