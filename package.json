{
  "name": "my-music-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @my-music-app/web dev",
    "build": "pnpm --filter @my-music-app/web build",
    "start": "pnpm --filter @my-music-app/web start",
    "lint": "pnpm --filter @my-music-app/web lint",
    "typecheck": "pnpm --filter @my-music-app/web typecheck",
    "test": "pnpm --filter @my-music-app/web test",
    "test:watch": "pnpm --filter @my-music-app/web test:watch",
    "test:coverage": "pnpm --filter @my-music-app/web test:coverage",
    "test:e2e": "pnpm --filter @my-music-app/web test:e2e",
    "format": "pnpm --filter @my-music-app/web format"
  }
}
